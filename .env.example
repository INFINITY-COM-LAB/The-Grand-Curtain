# Grand Curtain - Environment Configuration
# Copy this file to .env.local and fill in the values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000
VITE_API_MAX_RETRIES=2

# Analytics Configuration
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_FLUSH_INTERVAL=30000
VITE_MAX_ANALYTICS_QUEUE=50

# Feature Flags
VITE_FEATURE_EMAIL_VALIDATION=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_TICKETING=true
VITE_FEATURE_NEWSLETTER=true

# External Services (optional)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_STRIPE_PUBLIC_KEY=
# VITE_SENTRY_DSN=
